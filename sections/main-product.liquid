<link rel="stylesheet" href="{{ 'css-main-product.css' | asset_url }}">
<script type="module" src="{{ 'js-main-product.js' | asset_url}}" defer></script>
{% assign product_selected = section.settings.product_Id %}
{% assign sizes = product_selected.variants | map: 'option2' | uniq %}
{% assign colors = '' %}

<section class="product">
  <div class="product__header">
    <h2 class="product__title">{{ product_selected.title }}</h2>
    <span class="product__price">{{ product_selected.price | money }}</span>
    <img src="{{ product_selected.featured_image | image_url }}" class="product__image" width="400" height="400" alt="">
  </div>

  <div class="product__details" data-variants="{{ product_selected.variants | json | escape}}">
    <span class="product__label">Tamanho</span>
    <ul class="product__sizes">
      {% for size in sizes %}
        <li class="product__size">{{ size }}</li>
      {% endfor %}
    </ul>
    <span class="product__label">Cores</span>

    <ul class="product__colors">
      {% for variant in product_selected.variants %}
        {% unless colors contains variant.option1 %}
          {% if variant.featured_image != blank %}
            <li class="product__color" data-color="{{ variant.option1 }}">
              <img
                src="{{ variant.featured_image | image_url}}"
                alt="Sabrina 3 Flow {{ variant.option1 }}"
                width="80"
                height="80"
              >
            </li>
          {% endif %}

          {% assign colors = colors | append: variant.option1 | append: ',' %}
        {% endunless %}
      {% endfor %}
    </ul>

    <div class="product__footer">
      <div aria-label="Quantidade" class="product__quantity">
        <div class="product__quantity-controller" data-action='minus'>
          <img src="{{ 'icon-minius.svg' | asset_url}} " width="24" height="24" alt="">
        </div>
        <span class="product__quantity-value">1</span>
        <div class="product__quantity-controller" data-action='plus'>
          <img src="{{ 'icon-plus.svg' | asset_url}} " width="24" height="24" alt="">
        </div>
      </div>
    </div>
    <button type="button" class="button button--buy">
      Comprar <img src="{{ 'icon-shopping-bag.svg' | asset_url}}" width="24" height="24" alt="">
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Produto",
  "settings": [
    {
      "type": "product",
      "id": "product_Id",
      "label": "Produto"
    }
  ],
  "presets": [
    {
      "name": "Produto"
    }
  ]
}
{% endschema %}
