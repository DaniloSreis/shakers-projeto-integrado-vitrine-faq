<div class="header__cart-container">
  <button type="button" class="header__cart-open">
    <img
      src="{{ 'shopping-bag.svg' | asset_url }}"
      width="24"
      height="24"
      class="header__cart-icon"
      alt="Carrinho"
    >
  </button>

  <div class="header__cart-drawer">
    <img src="{{ 'shopping-bag.svg' | asset_url }}" width="24" height="24" class="header__cart-close" alt="">
    <div class="header__cart-content"></div>
    <button class="header__button-clear">Limpar Sacola</button>
  </div>
</div>
